{
  "name": "@latrinebot/cli",
  "version": "0.4.3",
  "description": "Tiny CLI over the Latrine Bot public API.",
  "license": "MIT",
  "author": "dfnwtf",
  "homepage": "https://github.com/dfnwtf/latrinebot/tree/main/cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/dfnwtf/latrinebot.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/dfnwtf/latrinebot/issues"
  },
  "keywords": [
    "latrine-bot",
    "latrinebot",
    "pumpfun",
    "solana",
    "cli"
  ],
  "type": "module",
  "bin": {
    "latrine": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@latrinebot/sdk": "^0.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
