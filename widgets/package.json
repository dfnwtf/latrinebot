{
  "name": "@latrinebot/widgets",
  "version": "0.4.5",
  "description": "Embeddable Latrine Bot widgets: live stats, holder list, status badge.",
  "license": "MIT",
  "author": "dfnwtf",
  "homepage": "https://github.com/dfnwtf/latrinebot/tree/main/widgets",
  "repository": {
