    "directory": "widgets"
  },
  "bugs": {
    "url": "https://github.com/dfnwtf/latrinebot/issues"
  },
  "keywords": [
    "latrine-bot",
    "latrinebot",
    "pumpfun",
    "solana",
    "widget",
